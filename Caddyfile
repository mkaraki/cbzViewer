{
	frankenphp
	auto_https off
}

:8080 {
	root public/
	encode zstd br gzip
    
    handle /internals/* {
    	respond "Not Found" 404
    }
    handle /vendor/* {
    	respond "Not Found" 404
    }
    handle /_config.php {
        respond "Not Found" 404
    }
    handle /robots.txt {
        respond "User-agent: *\nDisallow: /" 200
    }
    handle /favicon.ico {
        respond "Not Found" 404
    }
	handle {
        php_server {
            try_files {path} /index.php
        }
    }
    handle /assets/* {
        file_server
    }
    handle_path /api/* {
        root public/api
        php_server {
        	try_files {path}.php
        }
    }
}